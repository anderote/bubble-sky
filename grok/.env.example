# Copy to .env and fill in. Grok's brain is pluggable per role.
XAI_API_KEY=your-xai-api-key-here
# For a Claude-powered Architect (planner), add an Anthropic key:
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional overrides:
# Router/executor (frequent, keep cheap): default xai / grok-4.20-0309-non-reasoning
#   GROK_ROUTER_PROVIDER=xai
#   GROK_ROUTER_MODEL=grok-4.20-0309-non-reasoning
# Architect/planner (occasional, reasoning-heavy): default anthropic / claude-opus-4-8 when the key is set
#   GROK_ARCHITECT_PROVIDER=anthropic     # or xai
#   GROK_ARCHITECT_MODEL=claude-opus-4-8  # or claude-fable-5 (max), or a grok reasoning model
# XAI_MODEL=grok-4.20-0309-non-reasoning
# MC_HOST=localhost
# MC_PORT=25565
# MC_USER=Grok
