{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bubble-sky.dev/schemas/build-protocol/worker-progress.v1.schema.json",
  "title": "Bubble Sky Worker Progress v1",
  "type": "object",
  "required": ["schemaVersion", "taskId", "worker", "doneIds", "failedIds", "claimedIds"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "worker": { "type": "string", "minLength": 1 },
    "doneIds": { "$ref": "#/$defs/ids" },
    "failedIds": { "$ref": "#/$defs/ids" },
    "claimedIds": { "$ref": "#/$defs/ids" },
    "updatedAt": { "type": "string" }
  },
  "additionalProperties": true,
  "$defs": {
    "ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
