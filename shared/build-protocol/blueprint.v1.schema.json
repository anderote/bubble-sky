{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bubble-sky.dev/schemas/build-protocol/blueprint.v1.schema.json",
  "title": "Bubble Sky Semantic Blueprint v1",
  "type": "object",
  "required": ["schemaVersion", "name", "palette", "anchor", "regions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "style": { "type": "string" },
    "palette": { "type": "object", "additionalProperties": { "type": "string" } },
    "anchor": {
      "type": "object",
      "required": ["origin"],
      "properties": {
        "origin": { "$ref": "#/$defs/vec3" },
        "facing": { "type": "string" },
        "terrainFit": { "type": "string" }
      },
      "additionalProperties": true
    },
    "bounds": { "type": "object" },
    "regions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "phase", "components"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "phase": { "type": "number" },
          "components": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "required": ["kind"],
              "properties": { "kind": { "type": "string", "minLength": 1 } },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "vec3": {
      "type": "object", "required": ["x", "y", "z"],
      "properties": { "x": { "type": "integer" }, "y": { "type": "integer" }, "z": { "type": "integer" } },
      "additionalProperties": false
    }
  }
}
